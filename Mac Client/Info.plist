<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Identity -->
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    
    <key>CFBundleVersion</key>
    <string>1</string>
    
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>

    <!-- Network Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
            <key>127.0.0.1</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Permissions -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>This app needs local network access to communicate with Python server</string>
    
    <key>NSSystemAdministrationUsageDescription</key>
    <string>This app needs system access to communicate with USB radiation detection hardware</string>
    
    <key>NSAppleEventsUsageDescription</key>
    <string>This app needs to communicate with RadiaCode hardware</string>
    
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>This app may connect to RadiaCode devices via Bluetooth</string>
</dict>
</plist>
